<!doctype html>
<html lang="en">
<%- include('_head') %>
<body>
<style>
  html, body {
    margin: 0; padding: 0; min-height: 100vh;
    background: #f8f7f4;
  }
  .auth-sk-wrap {
    min-height: 100vh; display: flex;
    align-items: flex-start; justify-content: center; padding: 32px 24px;
  }
  .auth-sk-card {
    width: 100%; max-width: 680px; padding: 32px;
    background: #fff; border: 1px solid rgba(0,0,0,.12);
    border-radius: 24px; box-shadow: 0 1px 3px rgba(0,0,0,.04);
    box-sizing: border-box;
  }
  @keyframes auth-shimmer {
    0%   { background-position: -600px 0; }
    100% { background-position: 600px 0; }
  }
  .auth-sk-bar {
    background: linear-gradient(90deg, #ede9e3 25%, #f0ece6 50%, #ede9e3 75%);
    background-size: 1200px 100%;
    animation: auth-shimmer 1.6s infinite linear;
    border-radius: 4px;
  }
  .auth-sk-logo    { width: 150px; height: 44px; margin: 0 auto 28px; display: block; }
  .auth-sk-h       { width: 42%; height: 24px; margin-bottom: 10px; }
  .auth-sk-sub     { width: 65%; height: 14px; margin-bottom: 28px; }
  .auth-sk-label   { width: 120px; height: 11px; margin-bottom: 12px; margin-top: 22px; }
  .auth-sk-grid    { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 4px; }
  .auth-sk-field   { height: 56px; border-radius: 6px; }
  .auth-sk-field-f { width: 100%; height: 56px; border-radius: 6px; margin-bottom: 14px; }
  .auth-sk-btn     { width: 140px; height: 40px; border-radius: 6px; margin-left: auto; display: block; margin-top: 20px; }
</style>
  <div id="onboarding-root">
    <div class="auth-sk-wrap">
      <div class="auth-sk-card">
        <div class="auth-sk-bar auth-sk-logo"></div>
        <div class="auth-sk-bar auth-sk-h"></div>
        <div class="auth-sk-bar auth-sk-sub"></div>
        <div class="auth-sk-bar auth-sk-label"></div>
        <div class="auth-sk-grid">
          <div class="auth-sk-bar auth-sk-field"></div>
          <div class="auth-sk-bar auth-sk-field"></div>
          <div class="auth-sk-bar auth-sk-field"></div>
          <div class="auth-sk-bar auth-sk-field"></div>
          <div class="auth-sk-bar auth-sk-field"></div>
        </div>
        <div class="auth-sk-bar auth-sk-label"></div>
        <div class="auth-sk-grid">
          <div class="auth-sk-bar auth-sk-field"></div>
          <div class="auth-sk-bar auth-sk-field"></div>
        </div>
        <div class="auth-sk-bar auth-sk-field-f"></div>
        <div class="auth-sk-bar auth-sk-btn"></div>
      </div>
    </div>
  </div>
  <script type="module" src="/react/main.js"></script>
</body>
</html>
