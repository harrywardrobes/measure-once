<!doctype html>
<html lang="en">
<%- include('_head') %>
<body class="admin-page">

<style>
  /*/* Admin-only layout has moved to public/app-styles.css under the
     "Admin page" section. Every rule there is scoped under .admin-page
     (the <body> class below), so admin keeps its plum buttons / stone
     borders / custom tabs without colliding with shared rules used by
     other pages. The two former magic z-index values (toast=1000,
     modal-overlay=400) now consume --z-toast and --z-modal from the
     ladder defined on :root. Add new admin-only styles there, not here. */
</style>

<a href="#main-content" class="skip-link">Skip to content</a>
<div id="toast-live" aria-live="polite" aria-atomic="true" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;"></div><!-- inline-style-ok: sr-only live region -->
<div id="app-header-mount"></div>
<div id="viewer-banner" class="viewer-banner" style="display:none;" role="status"><!-- inline-style-ok: hidden by default, toggled by showViewerBanner() -->
  <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="flex-shrink:0;"><!-- inline-style-ok: icon sizing in flex context -->
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
  </svg>
  <span>Read-only access — you can view but not make changes. Contact an admin to request a higher access level.</span>
  <button onclick="dismissViewerBanner()" class="viewer-banner-close" aria-label="Dismiss read-only notice">
    <svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
      <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
    </svg>
  </button>
</div>
<div id="access-gate-mount"></div>

<div class="page" id="page">
  <h1 class="page-title">Admin Panel</h1>
  <div class="loading-state">Loading…</div>
</div>

<div id="toast" class="toast"></div>


<div id="app-bottom-bar-mount"></div>
<div id="command-palette-mount"></div>

<!--
  Search settings tab and other admin tabs are React islands built by
  `npm run build:react` into /react/main.js. The script self-mounts into
  each #tab-* panel when it loads, so switchTab(…) no longer needs a
  render call for those tabs.
-->
<script type="module" src="/react/main.js"></script>
<script>
  const $ = s => document.querySelector(s);
  const esc = s => (s == null ? '' : String(s)).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');

  /* ── Toast ── */
  function toast(msg, isErr) {
    const el = $('#toast');
    el.textContent = msg;
    el.className = 'toast show' + (isErr ? ' err' : '');
    clearTimeout(el._t);
    el._t = setTimeout(() => el.className = 'toast', 2400);
  }
  function showToast(msg, isErr) { toast(msg, isErr); }

  /* ── API helper ── */
  async function api(method, path, body) {
    const opts = { method, headers: { 'Content-Type': 'application/json' } };
    if (body !== undefined) opts.body = JSON.stringify(body);
    const r = await fetch(path, opts);
    if (r.status === 401) { window.location.href = '/'; return null; }
    if (r.status === 403) throw Object.assign(new Error('Forbidden'), { forbidden: true });
    const data = await r.json().catch(() => ({}));
    if (!r.ok) throw new Error(data.error || data.message || 'HTTP ' + r.status);
    return data;
  }

  /* ── Tabs ── */
  function switchTab(id) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === id));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.toggle('active', p.id === 'tab-' + id));
    try { localStorage.setItem('adminActiveTab', id); } catch (_) {}
    // Mount any React island in the newly-active panel on first use.
    // mountKnown() skips tab-panel elements that lack the `active` class,
    // so this call is a no-op for already-mounted or shell-only tabs.
    try { window.__reactIslandMount && window.__reactIslandMount(); } catch (_) {}
  }

  /* ── waitForElement ──────────────────────────────────────────────────────────
   * Returns a Promise that resolves to the element once it appears in the DOM,
   * using a MutationObserver so there is no busy-polling. Resolves to null if
   * the element does not appear within `timeout` ms (default 10 s).
   */
  function waitForElement(id, timeout) {
    const existing = document.getElementById(id);
    if (existing) return Promise.resolve(existing);
    return new Promise(function(resolve) {
      var timer = setTimeout(function() { observer.disconnect(); resolve(null); }, timeout || 10000);
      var observer = new MutationObserver(function() {
        var el = document.getElementById(id);
        if (el) { clearTimeout(timer); observer.disconnect(); resolve(el); }
      });
      observer.observe(document.body, { childList: true, subtree: true });
    });
  }

  // ── Dev environment tab visibility ─────────────────────────────────────────
  // The Dev Environment tab is always visible to admins — the DB-driven toggle
  // inside the tab controls dev-mode filtering. No visibility gating needed.
  function _applyDevEnvTabVisibility() {
    const btn   = document.getElementById('tab-btn-devenv');
    const panel = document.getElementById('tab-devenv');
    if (btn)   btn.hidden   = false;
    if (panel) panel.hidden = false;
  }

  // ── Init ───────────────────────────────────────────────────────────────────
  async function init() {
    let me;
    try {
      me = await api('GET', '/api/auth/user');
    } catch {
      window.location.href = '/';
      return;
    }
    if (!me?.isAdmin) {
      window.location.href = '/';
      return;
    }
    // Publish the authenticated user so the React GlobalHeader island
    // (src/react/components/GlobalHeader.tsx) can update its avatar.
    window.__moHeaderUser = me;
    try {
      window.dispatchEvent(new CustomEvent('mo:user', { detail: me }));
    } catch (_) {}

    // Team / Permissions / Requests / Audit log / Settings / Card actions /
    // Action handlers / Design visit / Dev environment are all React + MUI
    // islands — each component fetches its own data on mount. The admin shell
    // no longer pre-warms any data for those tabs.

    $('#page').innerHTML = `
      <h1 class="page-title">Admin Panel</h1>
      <p class="page-sub">Manage the team, permissions, and access requests.</p>

      <!-- React two-level grouped tab bar (AdminGroupedTabsBar.tsx) mounts
           here and hides the legacy .tabs strip below. The legacy strip
           stays in the DOM so switchTab(), inline onclick handlers, and
           existing tests still work unchanged. -->
      <div id="admin-grouped-tabs-mount"></div>

      <div class="tabs">
        <button class="tab-btn active" data-tab="team"        onclick="switchTab('team')">Team <span id="team-count" class="count-muted"></span><span id="team-conflict-badge"></span></button>
        <button class="tab-btn"        data-tab="permissions" onclick="switchTab('permissions')">Permissions &amp; roles</button>
        <button class="tab-btn"        data-tab="requests"    onclick="switchTab('requests')">Pending Requests <span id="req-tab-badge"></span></button>
        <button class="tab-btn"        data-tab="auditlog"    onclick="switchTab('auditlog')">Audit log</button>
        <button class="tab-btn"        data-tab="hubspot"     onclick="switchTab('hubspot')">HubSpot</button>
        <button class="tab-btn"        data-tab="quickbooks"  onclick="switchTab('quickbooks')">QuickBooks</button>
        <button class="tab-btn"        data-tab="settings"    onclick="switchTab('settings')">Settings</button>
        <button class="tab-btn"        data-tab="stages"      onclick="switchTab('stages')">Stages</button>
        <button class="tab-btn"        data-tab="cardactions"   onclick="switchTab('cardactions')">Card actions</button>
        <button class="tab-btn"        data-tab="actionhandlers" onclick="switchTab('actionhandlers')">Action handlers</button>
        <button class="tab-btn"        data-tab="designvisit"   onclick="switchTab('designvisit')">Design visit</button>
        <button class="tab-btn"        data-tab="search"        onclick="switchTab('search')">Search</button>
        <button class="tab-btn"        data-tab="emailtemplates" onclick="switchTab('emailtemplates')">Email templates</button>
        <button class="tab-btn"        data-tab="workflow"       onclick="switchTab('workflow')">Workflow</button>
        <button class="tab-btn"        data-tab="devenv"      onclick="switchTab('devenv')" id="tab-btn-devenv" hidden>Dev environment</button>
        <button class="tab-btn"        data-tab="offline"     onclick="switchTab('offline')">Offline support</button>
      </div>

      <!--
        TEAM / PERMISSIONS / REQUESTS / AUDIT LOG
        These four panels are React + MUI islands, mounted from
        src/react/pages/admin/*. The tab-panel divs below are the mount
        points; the React components own all data fetching and rendering.
        Cross-tab refresh is driven by the 'admin_data_changed'
        BroadcastChannel emitted from src/react/pages/admin/adminApi.ts.
      -->
      <div class="tab-panel active" id="tab-team"></div>
      <div class="tab-panel" id="tab-permissions"></div>
      <div class="tab-panel" id="tab-requests"></div>
      <div class="tab-panel" id="tab-auditlog"></div>

      <!-- HUBSPOT — React island (src/react/pages/admin/HubSpotPage.tsx).
           HubSpot CRM connection status / re-sync controls and webhook
           registration. Legacy inner element IDs (#hubspot-status-badge,
           #hubspot-status-row, #hubspot-webhooks-card) are preserved by the
           React component so external JS and tests still work unchanged.
      -->
      <div class="tab-panel" id="tab-hubspot"></div>

      <!-- QUICKBOOKS — React island (src/react/pages/admin/QuickBooksSettingsPage.tsx).
           Copy-me email/CC/BCC, deposit percentage, payment stages, and
           read-only connection info. -->
      <div class="tab-panel" id="tab-quickbooks"></div>

      <!-- SETTINGS / CARD ACTIONS / ACTION HANDLERS / DESIGN VISIT
           These four panels are React islands (src/react/pages/admin/*.tsx).
           Each component fetches its own data on mount. Legacy inner element
           IDs (#lead-statuses-table-wrap, #ls-new-key,
           #card-actions-table-wrap, #card-action-handlers-wrap,
           #card-action-handlers-conflict-banner, #dv-handles-wrap,
           #dv-furniture-wrap, #dv-door-styles-wrap, #dv-terms-current,
           #dv-terms-editor, #dv-terms-new-text, #dv-terms-history) are preserved by the
           React components so test selectors and cross-component calls still
           work unchanged.
      -->
      <div class="tab-panel" id="tab-settings"></div>
      <div class="tab-panel" id="tab-stages"></div>
      <div class="tab-panel" id="tab-cardactions"></div>
      <div class="tab-panel" id="tab-actionhandlers"></div>
      <div class="tab-panel" id="tab-designvisit"></div>

      <!-- SEARCH SETTINGS — React island (src/react/pages/SearchSettingsPage.tsx). -->
      <div class="tab-panel" id="tab-search"></div>


      <!-- EMAIL TEMPLATES — React island (src/react/pages/admin/EmailTemplatesPage.tsx). -->
      <div class="tab-panel" id="tab-emailtemplates"></div>
      <div class="tab-panel" id="tab-workflow"></div>

      <!-- DEV ENVIRONMENT
        ============================================================
        MAINTAINER NOTE — KEEP THIS PANEL UP TO DATE
        ============================================================
        Whenever you add a new dev-only feature to the admin panel
        (anything gated on NODE_ENV !== 'production', or otherwise
        hidden from the published app), you MUST add a corresponding
        entry to the DEV_ONLY_FEATURES array in
        src/react/pages/admin/DevEnvironmentPage.tsx.

        Each entry should include:
          1. The feature name
          2. The tab / location it lives in
          3. A short description of what it does AND why it is
             excluded from production.

        Convention is also documented in replit.md under
        "Dev-only admin features".
        ============================================================
        Dev environment tab is a React island
        (src/react/pages/admin/DevEnvironmentPage.tsx).
        The tab is always visible to admins. The DB-driven dev-mode
        toggle inside the tab controls hw_test_user filtering.
      -->
      <div class="tab-panel" id="tab-devenv" hidden></div>

      <!-- OFFLINE SUPPORT — React island (src/react/pages/admin/OfflineSupportPage.tsx).
           Capability matrix (config-driven), live sync status, and a lightweight
           conflicts review list over the Phase 2 offline write queue. -->
      <div class="tab-panel" id="tab-offline"></div>
    `;

    // Mount the React island synchronously now that the tab panels exist,
    // so panels don't briefly flash empty while the deferred bundle is
    // waiting on its MutationObserver fallback. See src/react/main.tsx.
    try { window.__reactIslandMount && window.__reactIslandMount(); } catch (_) {}

    const validTabs = ['team', 'permissions', 'requests', 'auditlog', 'hubspot', 'quickbooks', 'settings', 'stages', 'cardactions', 'actionhandlers', 'designvisit', 'search', 'emailtemplates', 'workflow', 'devenv', 'offline'];
    let savedTab;
    try { savedTab = localStorage.getItem('adminActiveTab'); } catch (_) {}
    if (savedTab && validTabs.includes(savedTab)) switchTab(savedTab);

    // Show the Dev Environment tab (always visible; toggle inside controls filtering).
    _applyDevEnvTabVisibility();
  }

  init();
</script>
</body>
</html>
