<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="theme-color" content="#200842">
  <meta name="color-scheme" content="light">
  <link rel="manifest" href="/manifest.json">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
  <link rel="apple-touch-icon" href="/icons/icon-192.png">
  <title><%= title %></title>
  <% if (typeof description !== 'undefined' && description) { %>
  <meta name="description" content="<%= description %>">
  <% } %>
  <% if (typeof ogTitle !== 'undefined' && ogTitle) { %>
  <meta property="og:title" content="<%= ogTitle %>">
  <% } %>
  <% if (typeof ogDescription !== 'undefined' && ogDescription) { %>
  <meta property="og:description" content="<%= ogDescription %>">
  <% } %>
  <% if (typeof ogUrl !== 'undefined' && ogUrl) { %>
  <meta property="og:url" content="<%= ogUrl %>">
  <% } %>
  <% if (typeof ogImage !== 'undefined' && ogImage) { %>
  <meta property="og:image" content="<%= ogImage %>">
  <% } %>
  <% if (typeof ogTitle !== 'undefined' && ogTitle) { %>
  <meta property="og:type" content="website">
  <% } %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!--
    Non-blocking font load: media="print" causes the browser to fetch the CSS
    without blocking first render; onload switches it to screen-media so fonts
    apply as soon as the stylesheet is ready. The <noscript> fallback restores
    the blocking load for environments with JavaScript disabled.
    Note: removing Google Fonts entirely is out of scope (design decision).
  -->
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Anton&family=Source+Code+Pro:wght@400;500;600&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Anton&family=Source+Code+Pro:wght@400;500;600&display=swap" rel="stylesheet"></noscript>
  <link rel="stylesheet" href="/tokens.css">
  <link rel="stylesheet" href="/app-styles.css">
</head>
