<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="theme-color" content="#200842">
  <meta name="color-scheme" content="light">
  <title><%= title %></title>
  <% if (typeof description !== 'undefined' && description) { %>
  <meta name="description" content="<%= description %>">
  <% } %>
  <% if (typeof ogTitle !== 'undefined' && ogTitle) { %>
  <meta property="og:title" content="<%= ogTitle %>">
  <% } %>
  <% if (typeof ogDescription !== 'undefined' && ogDescription) { %>
  <meta property="og:description" content="<%= ogDescription %>">
  <% } %>
  <% if (typeof ogUrl !== 'undefined' && ogUrl) { %>
  <meta property="og:url" content="<%= ogUrl %>">
  <% } %>
  <% if (typeof ogImage !== 'undefined' && ogImage) { %>
  <meta property="og:image" content="<%= ogImage %>">
  <% } %>
  <% if (typeof ogTitle !== 'undefined' && ogTitle) { %>
  <meta property="og:type" content="website">
  <% } %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Source+Code+Pro:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/tokens.css">
  <link rel="stylesheet" href="/app-styles.css">
</head>
