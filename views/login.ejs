<!doctype html>
<html lang="en">
<%- include('_head') %>
<body>
<style>
  html, body {
    margin: 0; padding: 0; min-height: 100vh;
    background: #f8f7f4;
  }
  .auth-sk-wrap {
    min-height: 100vh; display: flex;
    align-items: center; justify-content: center; padding: 24px;
  }
  .auth-sk-card {
    width: 100%; max-width: 440px; padding: 36px;
    background: #fff; border: 2px solid rgba(0,0,0,.12);
    border-radius: 24px; box-shadow: 0 2px 6px rgba(0,0,0,.06);
    box-sizing: border-box;
  }
  @keyframes auth-shimmer {
    0%   { background-position: -600px 0; }
    100% { background-position: 600px 0; }
  }
  .auth-sk-bar {
    background: linear-gradient(90deg, #ede9e3 25%, #f0ece6 50%, #ede9e3 75%);
    background-size: 1200px 100%;
    animation: auth-shimmer 1.6s infinite linear;
    border-radius: 4px;
  }
  .auth-sk-logo  { width: 150px; height: 44px; margin: 0 auto 28px; display: block; }
  .auth-sk-h     { width: 90px; height: 24px; margin-bottom: 10px; }
  .auth-sk-sub   { width: 78%; height: 14px; margin-bottom: 28px; }
  .auth-sk-field { width: 100%; height: 56px; border-radius: 6px; margin-bottom: 20px; }
  .auth-sk-btn   { width: 100%; height: 46px; border-radius: 6px; margin-top: 8px; }
  .auth-sk-foot  { width: 55%; height: 14px; margin: 28px auto 0; }
</style>
  <div id="login-root">
    <div class="auth-sk-wrap">
      <div class="auth-sk-card">
        <div class="auth-sk-bar auth-sk-logo"></div>
        <div class="auth-sk-bar auth-sk-h"></div>
        <div class="auth-sk-bar auth-sk-sub"></div>
        <div class="auth-sk-bar auth-sk-field"></div>
        <div class="auth-sk-bar auth-sk-field"></div>
        <div class="auth-sk-bar auth-sk-btn"></div>
        <div class="auth-sk-bar auth-sk-foot"></div>
      </div>
    </div>
  </div>
  <script type="module" src="/react/main.js"></script>
</body>
</html>
