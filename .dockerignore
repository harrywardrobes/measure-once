# Dependencies — reinstalled inside the image with `npm ci`.
node_modules

# Version control / CI metadata.
.git
.gitignore

# Local env / secrets — config is provided to the container via env vars only.
.env
.env.*

# Customer data (GDPR) — recreated empty at boot.
data/

# Tests and test output — not needed in the build or runtime image.
test/
test-results/
coverage/

# Build artifacts — regenerated by the builder stage and copied into runtime.
public/react/
public/storybook/
public/sw.js
storybook-static/

# Docs not needed at runtime.
docs/
*.md

# Editor / tooling caches.
.cache/
.config/
.claude/
.upm/
.pythonlibs/
.agents/
.local/
.storybook/main.ts.timestamp-*

# This file and the Dockerfile itself.
Dockerfile
.dockerignore
