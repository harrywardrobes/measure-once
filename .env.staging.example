# =============================================================================
# Measure Once — STAGING environment (staging.harrywardrobes.co.uk)
# =============================================================================
# Staging mirrors production (Cloud Run + Cloud SQL) but runs against an
# ISOLATED copy of the data and with the app's "dev mode" ON, so workflows can
# be exercised end-to-end against the LIVE HubSpot / QuickBooks / SMTP services
# while only touching test contacts (HubSpot `hw_test_user = 'true'`).
#
# On Cloud Run these are NOT a committed file — env vars are set with
# --set-env-vars and secrets with --set-secrets (see docs/environments.md).
# This file documents the exact staging values and is safe to commit (no
# secrets, only references).
#
# ⚠ Read docs/environments.md before deploying. The sharp edges are:
#   - dev mode is a DISPLAY filter, not a write guard. Only act on test contacts.
#   - NEVER register/modify HubSpot webhooks from staging — it repoints the
#     shared HubSpot app's webhook URL and breaks PRODUCTION webhooks.
#   - QuickBooks/Google tokens rotate; staging uses its OWN tokens. Run
#     `npm run staging:safety-reset` after every data clone.
# =============================================================================

# --- Core --------------------------------------------------------------------
NODE_ENV=production          # secure cookies + NO auto-migrate on boot
PORT=5000
APP_URL=https://staging.harrywardrobes.co.uk

# Leave RUN_MIGRATIONS_ON_BOOT UNSET. Apply migrations to staging deliberately
# with `DATABASE_URL=<staging> npm run db:migrate` before deploying a new image.

# --- Staging-specific secrets (DO NOT share with prod) -----------------------
# Its own database (isolated copy of prod data), session secret, and token keys.
DATABASE_URL=               # -> measureonce_staging on the Cloud SQL instance
SESSION_SECRET=             # new value, distinct from prod (openssl rand -hex 32)
QB_TOKEN_ENCRYPTION_KEY=    # new value (staging re-connects QB, so fresh key is fine)
GOOGLE_TOKEN_ENCRYPTION_KEY= # new value (staging re-connects Google)

# --- Object storage ----------------------------------------------------------
STORAGE_BACKEND=gcs
# Recommended: a SEPARATE staging bucket so test uploads don't land in the prod
# bucket. Trade-off: historical photos (whose keys live in the cloned DB) won't
# resolve in staging. To instead see historical photos, point this at the prod
# bucket and accept that new test uploads mix in alongside prod objects.
GCS_BUCKET=wardrobes-bucket-staging

# --- LIVE integrations (same services as production) -------------------------
# These reference the SAME live credentials as production (same HubSpot portal,
# same QuickBooks company, same mailbox). Safety comes from dev mode + only
# acting on test contacts — NOT from these being sandboxed.
HUBSPOT_ACCESS_TOKEN=        # same live private-app token as prod
QB_ENVIRONMENT=production    # live QuickBooks
QB_CLIENT_ID=                # same Intuit app as prod
QB_CLIENT_SECRET=
QB_REDIRECT_URI=https://staging.harrywardrobes.co.uk/auth/quickbooks/callback
GOOGLE_CLIENT_ID=            # same Google OAuth client as prod
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://staging.harrywardrobes.co.uk/auth/google/callback
GOOGLE_PLACES_API_KEY=
GOOGLE_SHARED_CALENDAR_ID=
SMTP_HOST=                   # live SMTP — real emails go to test contacts
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=

# --- Leave UNSET on staging --------------------------------------------------
# WEBHOOK_BASE_URL — do NOT set. Registering webhooks from staging would
# repoint the shared HubSpot app's webhook target away from production.
