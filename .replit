modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_database:1.0.0", "javascript_log_in_with_replit:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "test:privileges"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PRIVTEST_ALLOW_SHARED_DB=1 npm run test:privileges"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/mockup-sandbox"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
cwd = "./artifacts/mockup-sandbox"
waitForPort = 23636
router = "path"

[workflows.workflow.tasks.env]
PORT = "23636"
BASE_PATH = "/__mockup/"

[[workflows.workflow]]
name = "Reset Git Files"
mode = "sequential"
author = 58014399

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git remote | grep '^subrepl-' | while IFS= read -r r; do git remote remove \"$r\"; done"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5050
externalPort = 3001

[[ports]]
localPort = 23636
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["node", "server.js"]
build = ["sh", "-c", "npm run build:react && npm run build:storybook"]

[userenv]

[userenv.shared]
ADMIN_EMAILS = "harry@harrywardrobes.co.uk,harrygautierdesign@gmail.com"

[userenv.production]
APP_URL = "https://handle.harrywardrobes.co.uk"
NODE_ENV = "production"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 300000

[objectStorage]
defaultBucketID = "replit-objstore-a126686a-62c4-4b6f-98fe-45e6369588f2"
