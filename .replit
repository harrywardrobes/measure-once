modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_database:1.0.0", "javascript_log_in_with_replit:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:privileges"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"
waitForPort = 5000

[[workflows.workflow]]
name = "test:privileges"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PRIVTEST_ALLOW_SHARED_DB=1 npm run test:privileges"

[workflows.workflow.metadata]
isValidation = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5050
externalPort = 3001

[[ports]]
localPort = 5051
externalPort = 3002

[[ports]]
localPort = 5071
externalPort = 3003

[[ports]]
localPort = 23636
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["node", "server.js"]
build = ["sh", "-c", "npm run build:react && npm run build:storybook"]

[userenv]

[userenv.shared]
ADMIN_EMAILS = "harry@harrywardrobes.co.uk,harrygautierdesign@gmail.com"

[userenv.production]
APP_URL = "https://handle.harrywardrobes.co.uk"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[objectStorage]
defaultBucketID = "replit-objstore-a126686a-62c4-4b6f-98fe-45e6369588f2"
