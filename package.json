{
  "name": "measure-once",
  "version": "1.0.0",
  "description": "Project management dashboard",
  "main": "server.js",
  "scripts": {
    "postinstall": "npx puppeteer browsers install chrome",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./public/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./public/tailwind.css --watch",
    "test:privileges": "node test/privileges/run.js",
    "test:lead-status-sync": "node test/lead-status-sync/run.js",
    "test:lead-status-sync-customer-detail": "node test/lead-status-sync/customer-detail.js",
    "test:card-action-handlers": "node test/card-action-handlers/run.js",
    "test:hw-test-user": "node test/hw-test-user/run.js",
    "test:start-design-visit": "node test/start-design-visit/run.js",
    "test:keyboard-shortcuts": "node test/keyboard-shortcuts/run.js",
    "test:ci": "npm run test:privileges && npm run test:lead-status-sync && npm run test:lead-status-sync-customer-detail && npm run test:card-action-handlers && npm run test:hw-test-user && npm run test:start-design-visit",
    "backfill:ec-name-casing": "node scripts/backfill-ec-name-casing.js"
  },
  "dependencies": {
    "@acpr/rate-limit-postgresql": "^1.4.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express-session": "^1.19.0",
    "@types/memoizee": "^0.4.12",
    "@types/passport": "^1.0.17",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "googleapis": "^128.0.0",
    "memoizee": "^0.4.17",
    "nodemailer": "^8.0.7",
    "openid-client": "^6.8.3",
    "passport": "^0.7.0",
    "pg": "^8.20.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "puppeteer": "^24.43.1",
    "tailwindcss": "^3.4.19"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
